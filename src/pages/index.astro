---
import '../styles/global.css';

const linkedinUrl = 'https://www.linkedin.com/in/jawadbaig/';
const currentYear = '2026';

const navItems = [
  ['About', '#about'],
  ['Advisory Focus', '#advisory-focus'],
  ['Engagements', '#engagement'],
  ['Contact', '#contact']
];

const founderProof = [
  ['Former VP & CIO at Siemens', 'Enterprise technology, transformation, and governance leadership at global scale.'],
  ['20+ years in senior executive leadership', 'Operator-level judgment shaped by sustained accountability across functions.'],
  ['CFO and Head of Audit & Compliance experience', 'Finance, control, risk, and compliance perspectives in the same advisory frame.'],
  ['North American, European, and GCC market perspective', 'Advisory work shaped for leadership teams operating across regions.']
];

const heroLens = [
  ['Shape the agenda', 'Clarify what must change, why now, and who owns the next decision.'],
  ['Strengthen governance', 'Align decision rights, controls, and board-level accountability.'],
  ['Improve performance', 'Connect strategy to operating cadence, KPIs, and execution discipline.']
];

const advisoryFocus = [
  {
    title: 'AI Governance & ISO/IEC 42001 Readiness',
    body: 'Governance structures, accountability models, risk controls, and ISO/IEC 42001 readiness for responsible AI adoption.',
    useful: 'AI adoption needs clear ownership, controls, and readiness discipline.'
  },
  {
    title: 'Strategy & Operating Performance',
    body: 'Strategic planning, operating model clarity, KPI discipline, and performance improvement where execution needs structure.',
    useful: 'Direction exists, but operating choices and accountability need sharper form.'
  },
  {
    title: 'Digital Transformation & IT Leadership',
    body: 'CIO-level advisory across technology strategy, modernization priorities, IT governance, and transformation oversight.',
    useful: 'Technology decisions carry business, governance, and execution consequences.'
  },
  {
    title: 'Strategic Partnerships & Executive Support',
    body: 'Alliance structure, commercial partnership support, executive decision support, and interim or fractional leadership capacity.',
    useful: 'A strategic move needs structure, judgment, or temporary senior capacity.'
  }
];

const engageScenarios = [
  {
    title: 'Execution is stalling after strategy is set.',
    body: 'The plan is clear, but ownership, governance, and progress measures are not holding.'
  },
  {
    title: 'Transformation is consuming capital without enough control.',
    body: 'Decision cycles are slow, accountability is fuzzy, and leadership needs governance structure before adding another workstream.'
  },
  {
    title: 'Risk and governance need to be framed before commitment.',
    body: 'AI adoption, a major partnership, a market shift, or scale decision needs strategy and control architecture considered together.'
  },
  {
    title: 'Leadership capacity is the constraint.',
    body: 'The organization is in transition, scaling faster than the bench allows, or needs interim or fractional executive support.'
  }
];

const engagementModels = [
  {
    badge: 'Ongoing',
    title: 'Retained Advisory',
    body: 'Ongoing senior guidance for boards, owners, CEOs, and leadership teams navigating strategic, operational, governance, or transformation decisions.',
    points: ['Defined advisory scope', 'Recurring touchpoints'],
    best: 'Leadership teams that need continuity across evolving priorities.'
  },
  {
    badge: 'Scoped Project',
    title: 'Scoped Engagement',
    body: 'A defined advisory engagement for a specific strategy, transformation, governance, AI readiness, or operating-performance need, with clear objectives and decision points.',
    points: ['Clear scope', 'Defined deliverables'],
    best: 'A specific strategic, governance, or transformation need that requires focused senior attention.'
  },
  {
    badge: 'Embedded Support',
    title: 'Interim / Fractional Executive Support',
    body: 'Interim or part-time executive support during transition, transformation, or capability gaps where experienced leadership is needed without a full-time appointment.',
    points: ['Embedded leadership support', 'Structured transition coverage'],
    best: 'Periods of transition, growth, or temporary leadership capacity gaps.'
  }
];

const interestOptions = [
  'AI Governance & ISO/IEC 42001 Readiness',
  'Strategy & Operating Performance',
  'Digital Transformation & IT Leadership',
  'Strategic Partnerships & Executive Support',
  'Interim / Fractional Executive Support',
  'Other'
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>BAIG Advisory | Senior Executive Advisory</title>
    <meta name="description" content="Senior executive advisory for leaders navigating complex change across strategy, governance, transformation, partnerships, and AI readiness." />
    <link rel="canonical" href="https://baigadvisory.us/" />
    <meta property="og:title" content="BAIG Advisory | Senior Executive Advisory" />
    <meta property="og:description" content="Senior executive advisory for leaders navigating complex change across strategy, governance, transformation, partnerships, and AI readiness." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://baigadvisory.us/" />
    <meta property="og:site_name" content="BAIG Advisory" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content="https://baigadvisory.us/assets/baig-advisory-social-v2.png" />
    <meta property="og:image:secure_url" content="https://baigadvisory.us/assets/baig-advisory-social-v2.png" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="BAIG Advisory social preview with the message Strategy for leaders navigating complex change." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="BAIG Advisory | Senior Executive Advisory" />
    <meta name="twitter:description" content="Senior executive advisory for leaders navigating complex change across strategy, governance, transformation, partnerships, and AI readiness." />
    <meta name="twitter:image" content="https://baigadvisory.us/assets/baig-advisory-social-v2.png" />
    <meta name="twitter:image:alt" content="BAIG Advisory social preview with the message Strategy for leaders navigating complex change." />
    <link rel="icon" type="image/svg+xml" href="/assets/baig-advisory-icon.svg" />
    <link rel="apple-touch-icon" href="/assets/icon.png" />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@500,700,800&f[]=satoshi@400,500,700&display=swap" rel="stylesheet" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'ProfessionalService',
          name: 'BAIG Advisory',
          description: 'Senior executive advisory and consulting across business strategy, digital transformation, governance, and strategic partnerships, serving North America, Europe, and the GCC.',
          areaServed: ['North America', 'Europe', 'GCC'],
          address: {
            '@type': 'PostalAddress',
            addressLocality: 'Alpharetta',
            addressRegion: 'Georgia',
            addressCountry: 'US'
          },
          founder: { '@id': '#jawad-baig' },
          sameAs: [linkedinUrl]
        },
        {
          '@type': 'Person',
          '@id': '#jawad-baig',
          name: 'Jawad Baig',
          jobTitle: 'Founder & Principal Advisor',
          worksFor: { '@type': 'Organization', name: 'BAIG Advisory' },
          sameAs: [linkedinUrl]
        },
        {
          '@type': 'Organization',
          name: 'BAIG Advisory',
          founder: { '@id': '#jawad-baig' }
        }
      ]
    })} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header" data-header>
      <nav class="nav-shell" aria-label="Primary navigation">
        <a class="brand-lockup brand-lockup--dark" href="/" aria-label="BAIG Advisory home">
          <img class="brand-icon" src="/assets/baig-advisory-icon.svg" alt="" width="40" height="40" aria-hidden="true" />
          <span class="brand-wordmark" aria-hidden="true">
            <span class="brand-wordmark__name">BAIG</span>
            <span class="brand-wordmark__descriptor">Advisory</span>
          </span>
        </a>

        <ul class="nav-links" role="list">
          {navItems.map(([label, href]) => (
            <li><a href={href}>{label}</a></li>
          ))}
        </ul>

        <div class="nav-actions">
          <a class="button button--primary nav-cta" href="#contact">Start a Conversation</a>
          <button class="menu-button" type="button" data-menu-toggle aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
            <span></span>
            <span></span>
            <span></span>
          </button>
        </div>
      </nav>

      <div class="mobile-menu" id="mobile-menu" data-mobile-menu hidden>
        <div class="mobile-menu__panel">
          <div class="mobile-menu__top">
            <a class="brand-lockup brand-lockup--dark brand-lockup--mobile" href="/" aria-label="BAIG Advisory home">
              <img class="brand-icon" src="/assets/baig-advisory-icon.svg" alt="" width="40" height="40" aria-hidden="true" />
              <span class="brand-wordmark" aria-hidden="true">
                <span class="brand-wordmark__name">BAIG</span>
                <span class="brand-wordmark__descriptor">Advisory</span>
              </span>
            </a>
            <button class="icon-button" type="button" data-menu-close aria-label="Close menu">Close</button>
          </div>
          <ul role="list">
            {navItems.map(([label, href]) => (
              <li><a href={href}>{label}</a></li>
            ))}
          </ul>
          <a class="button button--primary" href="#contact">Start a Conversation</a>
        </div>
      </div>
    </header>

    <main id="main">
      <section class="hero section-dark" aria-labelledby="hero-title">
        <div class="hero__inner">
          <div class="hero__content reveal reveal--hero" data-reveal-seq="0">
            <p class="kicker">BAIG Advisory</p>
            <h1 id="hero-title">Strategy for leaders navigating complex change.</h1>
            <p class="hero__lead">BAIG Advisory works with senior executives, boards, and investors to shape transformation agendas, strengthen governance, and improve operating performance across high-stakes environments.</p>
            <div class="hero__actions">
              <a class="button button--gold" href="#contact">Start a Conversation</a>
              <a class="button button--ghost" href="#advisory-focus">Explore Advisory Focus</a>
            </div>
          </div>

          <aside class="hero-brief reveal reveal--panel" data-reveal-seq="1" aria-label="Advisory priorities">
            <div class="hero-brief__list">
              {heroLens.map(([title, body]) => (
                <article class="hero-brief__item">
                  <h2>{title}</h2>
                  <p>{body}</p>
                </article>
              ))}
            </div>
          </aside>
        </div>
      </section>

      <section class="section founder-section" id="about" aria-labelledby="about-title">
        <div class="section-grid section-grid--about">
          <div class="section-copy section-copy--founder reveal">
            <h2 id="about-title">Executive advisory grounded in real operating accountability.</h2>
            <span class="section-rule" aria-hidden="true"></span>
            <p>BAIG Advisory is led by Jawad Baig, Founder &amp; Principal Advisor, with more than two decades of executive leadership across strategy, technology, finance, governance, audit, compliance, and transformation.</p>
          </div>

          <div class="about-ledger reveal">
            <div class="about-founder">
              <img src="/assets/jawad-baig-cropped.png" alt="Jawad Baig, Founder and Principal Advisor" width="3011" height="3011" loading="lazy" />
              <div class="about-ledger__intro">
                <h3>Jawad Baig</h3>
                <p>Founder &amp; Principal Advisor</p>
                <span class="section-rule section-rule--compact" aria-hidden="true"></span>
              </div>
            </div>
            <ul role="list">
              {founderProof.map(([title, body]) => (
                <li>
                  <strong>{title}</strong>
                  <span>{body}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <section class="section section-muted" id="advisory-focus" aria-labelledby="advisory-focus-title">
        <div class="section-intro reveal">
          <h2 id="advisory-focus-title">Advisory focus</h2>
          <p>Four advisory priorities for leadership teams that need strategy, governance, technology, and execution decisions to hold together.</p>
        </div>
        <div class="focus-rail">
          {advisoryFocus.map((item) => (
            <article class:list={['focus-card', 'reveal']} data-reveal-seq="2">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
              <p class="useful-when"><strong>Useful when:</strong> {item.useful}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section section-dark" id="when-to-engage" aria-labelledby="engage-title">
        <div class="engage-shell">
          <div class="engage-grid">
            <div class="section-intro section-intro--dark reveal">
              <h2 id="engage-title">When to bring BAIG Advisory in</h2>
              <p>You need senior operating judgment when the decision crosses functions, carries execution risk, or will shape the next 12-24 months.</p>
            </div>
            <div class="scenario-list" aria-label="When to engage BAIG Advisory">
              {engageScenarios.map((scenario) => (
                <article class="scenario-item reveal" data-reveal-seq="2">
                  <span class="scenario-item__marker" aria-hidden="true"></span>
                  <div class="scenario-item__body">
                    <h3>{scenario.title}</h3>
                    <p>{scenario.body}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section class="section engagement-section" id="engagement" aria-labelledby="engagement-title">
        <div class="section-intro reveal">
          <h2 id="engagement-title">How BAIG Advisory works.</h2>
          <p>Three engagement models built around senior access and a clear operating rhythm.</p>
        </div>
        <div class="engagement-grid">
          {engagementModels.map((model) => (
            <article class:list={['engagement-card', 'reveal']} data-reveal-seq="2">
              <span class="model-badge">{model.badge}</span>
              <h3>{model.title}</h3>
              <p>{model.body}</p>
              <ul role="list">
                {model.points.map((point) => <li>{point}</li>)}
              </ul>
              <p class="best-for"><strong>Best for:</strong> {model.best}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section contact-section section-dark" id="contact" aria-labelledby="contact-title">
        <div class="contact-grid">
          <div class="section-copy reveal">
            <h2 id="contact-title">Start an advisory conversation.</h2>
            <p>Share the decision, transformation, governance challenge, AI readiness priority, or leadership need you are working through. BAIG Advisory will review the context and respond with an appropriate next step.</p>
            <dl class="contact-list">
              <div>
                <dt>Headquarters</dt>
                <dd>Alpharetta, Georgia, USA</dd>
              </div>
              <div>
                <dt>Market Coverage</dt>
                <dd>North America, Europe, and the GCC</dd>
              </div>
              <div>
                <dt>LinkedIn</dt>
                <dd><a href={linkedinUrl} target="_blank" rel="noopener noreferrer">Connect on LinkedIn</a></dd>
              </div>
              <div>
                <dt>Response Time</dt>
                <dd>Within 24&ndash;48 hours</dd>
              </div>
            </dl>
          </div>

          <div class="form-panel reveal">
            <h3>Start the Conversation</h3>
            <form
              name="baig-advisory-inquiry"
              method="POST"
              action="/api/contact"
              data-success-url="/success/"
              data-contact-form
            >
              <p class="hidden-field">
                <label>Do not fill this out: <input name="bot-field" /></label>
              </p>
              <div class="form-row">
                <label for="firstName">
                  <span>First Name</span>
                  <input id="firstName" name="firstName" autocomplete="given-name" required />
                </label>
                <label for="lastName">
                  <span>Last Name</span>
                  <input id="lastName" name="lastName" autocomplete="family-name" required />
                </label>
              </div>
              <label for="email">
                <span>Work Email</span>
                <input id="email" name="email" type="email" autocomplete="email" required />
              </label>
              <label for="company">
                <span>Company / Organization</span>
                <input id="company" name="company" autocomplete="organization" />
              </label>
              <label for="role">
                <span>Role / Title</span>
                <input id="role" name="role" autocomplete="organization-title" />
              </label>
              <label for="interest">
                <span>Area of Interest</span>
                <select id="interest" name="interest" required>
                  <option value="">Select one</option>
                  {interestOptions.map((option) => <option value={option}>{option}</option>)}
                </select>
              </label>
              <label for="message">
                <span>Message</span>
                <textarea id="message" name="message" rows="5" required></textarea>
              </label>
              <p class="form-message" data-form-message role="status" aria-live="polite"></p>
              <button class="button button--gold" type="submit">Send Inquiry</button>
            </form>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-grid">
        <div>
          <a class="brand-lockup brand-lockup--dark" href="/" aria-label="BAIG Advisory home">
            <img class="brand-logo" src="/assets/baig-advisory-logo.svg" alt="BAIG Advisory" width="220" height="68" />
          </a>
          <p>Senior executive advisory across strategy, governance, transformation, strategic partnerships, and AI Governance &amp; ISO/IEC 42001 Readiness.</p>
        </div>
        <div>
          <h2>Advisory Focus</h2>
          <ul role="list">
            <li><a href="#advisory-focus">AI Governance & ISO/IEC 42001 Readiness</a></li>
            <li><a href="#advisory-focus">Strategy & Operating Performance</a></li>
            <li><a href="#advisory-focus">Digital Transformation & IT Leadership</a></li>
            <li><a href="#advisory-focus">Strategic Partnerships & Executive Support</a></li>
          </ul>
        </div>
        <div>
          <h2>Firm</h2>
          <ul role="list">
            <li><a href="#about">About</a></li>
            <li><a href="#when-to-engage">When to Engage</a></li>
            <li><a href="#engagement">Engagements</a></li>
          </ul>
        </div>
        <div>
          <h2>Connect</h2>
          <ul role="list">
            <li><a href="#contact">Contact Us</a></li>
            <li><a href={linkedinUrl} target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
            <li><a href="#contact">Start a Conversation</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; {currentYear} BAIG Advisory. All rights reserved.</p>
        <p>Alpharetta, Georgia, USA &middot; North America, Europe, and the GCC</p>
      </div>
    </footer>

    <script>
      import '../scripts/site.js';
    </script>
  </body>
</html>
