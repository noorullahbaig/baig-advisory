---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/assets/baig-advisory-icon.svg" />
    <title>Inquiry Received | BAIG Advisory</title>
  </head>
  <body class="simple-page">
    <main class="simple-page__panel">
      <a class="brand-lockup brand-lockup--dark" href="/" aria-label="BAIG Advisory home">
        <img class="brand-icon" src="/assets/baig-advisory-icon.svg" alt="" width="40" height="40" aria-hidden="true" />
        <span class="brand-wordmark" aria-hidden="true">
          <span class="brand-wordmark__name">BAIG</span>
          <span class="brand-wordmark__descriptor">Advisory</span>
        </span>
      </a>
      <h1>Inquiry received.</h1>
      <p>Thank you for reaching out. BAIG Advisory will review the context and respond with an appropriate next step.</p>
      <a class="button button--primary" href="/">Return to homepage</a>
    </main>
  </body>
</html>
