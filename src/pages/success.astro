---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/assets/baig-advisory-icon.svg" />
    <title>Inquiry Received | BAIG Advisory</title>
  </head>
  <body class="simple-page">
    <main class="simple-page__panel">
      <a class="brand-lockup brand-lockup--dark brand-lockup--plate" href="/" aria-label="BAIG Advisory home">
        <img class="brand-logo" src="/assets/baig-advisory-logo.svg" alt="BAIG Advisory" width="220" height="68" />
      </a>
      <h1>Inquiry received.</h1>
      <p>Thank you for reaching out. We will review your inquiry and respond within 24&ndash;48 hours.</p>
      <a class="button button--primary" href="/">Return to homepage</a>
    </main>
  </body>
</html>
